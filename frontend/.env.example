# Copia este archivo a `.env` (no se commitea) y rellena con tus credenciales reales.
# Para obtener estas keys: Supabase → Project Settings → API.
# IMPORTANTE: usa SOLO la `anon public` key, NUNCA la `service_role`.
VITE_SUPABASE_URL=https://<tu-proyecto>.supabase.co
VITE_SUPABASE_ANON_KEY=<tu-anon-public-key>

# Push notifications PWA — par VAPID. Genera con:
#   npx web-push generate-vapid-keys
# La PÚBLICA va aquí (el browser la usa para crear la PushSubscription).
# La PRIVADA va a Supabase Edge Functions secrets:
#   supabase secrets set VAPID_PRIVATE_KEY=<priv> VAPID_PUBLIC_KEY=<pub> VAPID_SUBJECT=mailto:tu@email.com
VITE_VAPID_PUBLIC_KEY=<tu-vapid-public-key>

# Master switch: 'true' habilita el toggle Push real. 'false' (default) lo
# muestra como "Próximamente" sin intentar suscribir. Activarlo solo cuando
# hayas configurado VAPID_PRIVATE_KEY en Supabase secrets y deployado send-push.
VITE_PUSH_ENABLED=false

# Soporte y Ayuda — atajos directos en el modal de soporte (opcionales).
# Si VITE_SUPPORT_WHATSAPP queda vacío, el botón de WhatsApp no aparece.
# Formato WA: número internacional sin '+' ni espacios, ej: 56912345678
VITE_SUPPORT_EMAIL=soporte@neurostrategia.cl
VITE_SUPPORT_WHATSAPP=

# Mercado Pago Marketplace — pagos reales con escrow.
# Activar SOLO cuando hayas registrado una app Marketplace en MP Developers
# y configurado MP_CLIENT_SECRET / MP_ACCESS_TOKEN / MP_WEBHOOK_SECRET en
# Supabase secrets. Mientras esté en 'false', el botón muestra "Próximamente".
VITE_MP_ENABLED=false
VITE_MP_CLIENT_ID=

# Monitoreo de errores (Sentry). OPCIONAL: si queda vacío, el monitoreo está
# inerte (los errores solo van a consola). Para activarlo:
#   1. Crear proyecto en https://sentry.io (plan gratis) → copiar el DSN.
#   2. Pegar el DSN aquí y en las env vars del deploy (Vercel/Netlify).
#   3. Redeploy. Los errores no capturados llegarán a Sentry con traza.
VITE_SENTRY_DSN=
