# ============================================================
# Freelancy — .gitignore raíz
# ============================================================

# --- Dependencias ---
node_modules/
**/node_modules/

# --- Builds ---
dist/
dist-ssr/
build/
**/dist/

# --- Variables de entorno (NUNCA subir secretos) ---
.env
.env.*
!.env.example
**/.env
**/.env.*
!**/.env.example

# --- Vite: archivos temporales de config (la basura que había en el repo) ---
**/vite.config.js.timestamp-*
**/vite.config.ts.timestamp-*
*.timestamp-*.mjs

# --- Logs ---
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# --- Sistema operativo ---
.DS_Store
**/.DS_Store
Thumbs.db

# --- Editores / IDE ---
.vscode/*
!.vscode/extensions.json
.idea/
*.swp
*.sw?

# --- Deploy ---
.vercel/
**/.vercel/

# --- Supabase (CLI local) ---
supabase/.branches/
supabase/.temp/
supabase/.env
